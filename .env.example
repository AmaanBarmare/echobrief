# ============================================================
# EchoBrief Environment Variables
# Copy this to .env.local and fill in your values
# Never commit .env.local to Git!
# ============================================================

# ---- Frontend (Vite) ----
# These are exposed to the browser (prefixed with VITE_)

VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-supabase-anon-key>
VITE_CHROME_EXTENSION_STORE_URL=<your-chrome-web-store-url>

# ---- Supabase Edge Function Secrets ----
# Set these in: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# Do NOT prefix with VITE_ — these must never be in frontend code

# Core (required)
SUPABASE_URL=https://<your-project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
# Only required by the upload-recording Edge Function for auth token verification
SUPABASE_ANON_KEY=<your-anon-key>

# AI / Processing
OPENAI_API_KEY=<your-openai-api-key>

# Primary transcription provider (recommended / current default path)
SARVAM_API_KEY=<your-sarvam-api-key>
SARVAM_WEBHOOK_SECRET=<a-random-secret-string-for-sarvam-callback-auth>

# Bot recording
RECALL_API_KEY=<your-recall-api-key>
RECALL_API_BASE_URL=https://<your-recall-region>.recall.ai
RECALL_WEBHOOK_SECRET=<whsec-or-svix-webhook-secret>

# Google Calendar OAuth
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<your-google-oauth-client-secret>

# Optional delivery integrations
SLACK_BOT_TOKEN=<xoxb-your-slack-bot-token>
RESEND_API_KEY=<your-resend-api-key>

# Optional product integrations
NOTION_CLIENT_ID=<your-notion-oauth-client-id>
NOTION_CLIENT_SECRET=<your-notion-oauth-client-secret>

GUPSHUP_API_KEY=<your-gupshup-api-key>
GUPSHUP_PHONE_NUMBER=<your-gupshup-registered-phone>
